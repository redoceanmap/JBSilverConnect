# JB Silver Connect 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (cp .env.example .env)

# AI 기능용 Gemini API 키 (https://aistudio.google.com/apikey)
# 비워두면 자동으로 Mock 응답으로 폴백됩니다.
GEMINI_API_KEY=

# 네이버 API 키 — 백엔드 지점 검색용 (developers.naver.com → 앱 → Client ID / Secret)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 네이버 지도 JavaScript 앱 키 — 프론트 지도 표시용 (동일한 Client ID 사용)
NEXT_PUBLIC_NAVER_CLIENT_ID=

# 데모 사용자 ID
DEMO_USER_ID=user_kim_sonja
