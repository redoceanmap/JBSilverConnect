# JB Silver Connect 환경 변수 예시
# 이 파일을 .env 로 복사한 뒤 값을 채우세요. (cp .env.example .env)

# AI 기능용 Gemini API 키 (https://aistudio.google.com/apikey)
# 비워두면 자동으로 Mock 응답으로 폴백됩니다.
GEMINI_API_KEY=

# 카카오 REST API 키 — 백엔드 지점 검색용 (developers.kakao.com → 앱 키 → REST API 키)
KAKAO_REST_KEY=

# 카카오 JavaScript 앱 키 — 프론트 지도 표시용 (developers.kakao.com → 앱 키 → JavaScript 키)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# 데모 사용자 ID
DEMO_USER_ID=user_kim_sonja
